# Primary OpenAI-compatible settings
OPENAI_BASE_URL=https://<your-endpoint>/openai/v1/
# Optional for Azure endpoints when using DefaultAzureCredential
# OPENAI_API_KEY=<your-api-key>
OPENAI_CHAT_MODEL=<chat-model-or-deployment-name>
OPENAI_EMBEDDING_MODEL=<embedding-model-or-deployment-name>
OPENAI_API_VERSION=2024-10-21

# Optional if embeddings use a different endpoint/key
# OPENAI_EMBEDDING_BASE_URL=https://<embedding-endpoint>/openai/v1/
# OPENAI_EMBEDDING_API_KEY=<embedding-api-key>

AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
# Optional for Azure Search when using DefaultAzureCredential
# AZURE_SEARCH_API_KEY=<your-search-key>
AZURE_SEARCH_INDEX_NAME=pdf-rag-index

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5
EMBEDDING_DIMENSIONS=1536
EMBEDDING_CACHE_DB_PATH=.cache/embeddings.sqlite3
